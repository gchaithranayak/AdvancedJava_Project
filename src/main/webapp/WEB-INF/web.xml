<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>HospitalwebApp1</display-name>

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ADD PATIENT -->
    <servlet>
        <servlet-name>Add</servlet-name>
        <servlet-class>com.servlet.AddPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Add</servlet-name>
        <url-pattern>/AddPatientServlet</url-pattern>
    </servlet-mapping>

    <!-- UPDATE PATIENT -->
    <servlet>
        <servlet-name>Update</servlet-name>
        <servlet-class>com.servlet.UpdatePatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Update</servlet-name>
        <url-pattern>/UpdatePatientServlet</url-pattern>
    </servlet-mapping>

    <!-- DELETE PATIENT (STEP 1 - SHOW DETAILS) -->
    <servlet>
        <servlet-name>Delete</servlet-name>
        <servlet-class>com.servlet.DeletePatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Delete</servlet-name>
        <url-pattern>/DeletePatientServlet</url-pattern>
    </servlet-mapping>

    <!-- CONFIRM DELETE (STEP 2 - ACTUAL DELETE) -->
    <servlet>
        <servlet-name>ConfirmDelete</servlet-name>
        <servlet-class>com.servlet.ConfirmDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConfirmDelete</servlet-name>
        <url-pattern>/ConfirmDeleteServlet</url-pattern>
    </servlet-mapping>

    <!-- REPORT CRITERIA -->
    <servlet>
        <servlet-name>Criteria</servlet-name>
        <servlet-class>com.servlet.ReportCriteriaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Criteria</servlet-name>
        <url-pattern>/ReportCriteriaServlet</url-pattern>
    </servlet-mapping>

    <!-- REPORT -->
    <servlet>
        <servlet-name>Report</servlet-name>
        <servlet-class>com.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Report</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

</web-app>
